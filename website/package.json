{
	"name": "website",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"deploy": "rm -rf .next .open-next && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"preview:fresh": "rm -rf .next .open-next && opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"sync-r2": "./scripts/sync-r2.sh",
		"sync-r2:folder": "./scripts/sync-r2.sh --folder",
		"sync-r2:watch": "npx chokidar 'react-native/**' 'react-native-usage/**' 'react-native-types/**' -c './scripts/sync-r2.sh {path}'"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.17.1",
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@types/mdx": "^2.0.13",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"framer-motion": "^12.34.4",
		"fumadocs-core": "^16.6.8",
		"fumadocs-mdx": "^14.2.9",
		"fumadocs-typescript": "^5.1.5",
		"fumadocs-ui": "^16.6.8",
		"lucide-react": "^0.576.0",
		"motion": "^12.34.4",
		"next": "16.1.5",
		"next-view-transitions": "^0.3.5",
		"react": "19.1.5",
		"react-dom": "19.1.5",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "~4.1.17",
		"@types/node": "^20.19.35",
		"@types/react": "^19.1.5",
		"@types/react-dom": "^19.1.5",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"tailwindcss": "~4.1.17",
		"typescript": "^5.7.4",
		"wrangler": "^4.69.0"
	}
}